{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-hack.local/schemas/normalized_fact.json",
  "title": "NormalizedFact",
  "type": "object",
  "required": ["normalized_fact_id", "brand_id", "source_page_id", "url", "page_type", "last_crawled_at"],
  "additionalProperties": false,
  "properties": {
    "normalized_fact_id": { "type": "string", "format": "uuid" },
    "brand_id": { "type": "string", "format": "uuid" },
    "source_page_id": { "type": "string", "format": "uuid" },
    "url": { "type": "string", "format": "uri" },
    "page_type": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "products": { "type": "array", "items": { "type": "string" }, "default": [] },
    "features": { "type": "array", "items": { "type": "string" }, "default": [] },
    "pain_points": { "type": "array", "items": { "type": "string" }, "default": [] },
    "customer_types": { "type": "array", "items": { "type": "string" }, "default": [] },
    "industries": { "type": "array", "items": { "type": "string" }, "default": [] },
    "pricing_terms": { "type": "array", "items": { "type": "string" }, "default": [] },
    "brand_phrases": { "type": "array", "items": { "type": "string" }, "default": [] },
    "competitor_mentions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_type": { "type": "string" },
    "last_crawled_at": { "type": "string", "format": "date-time" }
  }
}
